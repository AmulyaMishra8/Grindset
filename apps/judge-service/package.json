{
    "name": "@grindset/judge-service",
    "version": "0.0.1",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "prisma generate && tsc",
        "typecheck": "prisma generate && tsc --noEmit",
        "db:push": "prisma db push",
        "db:generate": "prisma generate",
        "db:seed": "tsx prisma/seed.ts",
        "db:studio": "prisma studio",
        "start": "node dist/index.js"
    },
    "dependencies": {
        "@grindset/db": "workspace:*",
        "@grindset/shared-types": "workspace:*",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.0",
        "jose": "^5.6.3",
        "pg": "^8.22.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.0.0",
        "@types/pg": "^8.20.0",
        "prisma": "^7.8.0",
        "tsx": "^4.11.0",
        "typescript": "^5.4.0"
    }
}
