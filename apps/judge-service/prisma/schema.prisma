generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Problem {
  id                 Int           @id @default(autoincrement())
  slug               String        @unique
  title              String
  domain             String
  difficulty         String
  estimatedMinutes   Int
  problemStatement   String
  sealedExpectations Json
  chatFormat         Json?
  referenceCode      Json?
  starterCode        Json?         // per-language stub the editor pre-fills
  testCases          Json?         // { functionName, isAsync, cases: [...] } run on the sandbox
  createdAt          DateTime      @default(now())
  practiceSets       PracticeSet[]
  testSets           TestSet[]
  submissions        Submission[]
}

// One row per /submit that made it as far as running the tests. `userId` is the
// auth-service user id — no FK, because users live in a different database
// (Supabase) than this one (Neon).
model Submission {
  id        Int      @id @default(autoincrement())
  userId    String
  problemId Int
  problem   Problem  @relation(fields: [problemId], references: [id])
  mode      String   // "practice" | "test"
  language  String
  passed    Int
  total     Int
  solved    Boolean  // passed == total && total > 0, denormalised so stats stay a plain count
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, problemId])
}

model PracticeSet {
  id        Int     @id @default(autoincrement())
  problemId Int     @unique
  problem   Problem @relation(fields: [problemId], references: [id])
}

model TestSet {
  id        Int     @id @default(autoincrement())
  problemId Int     @unique
  problem   Problem @relation(fields: [problemId], references: [id])
}
