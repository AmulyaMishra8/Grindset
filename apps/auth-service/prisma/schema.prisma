generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A registered person. Credentials live here too (one set per user for v1).
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  passwordHash  String?  // null when the account is OAuth-only
  displayName   String?
  status        UserStatus @default(ACTIVE)

  // MFA
  mfaEnabled       Boolean @default(false)
  mfaSecret        String? // encrypted TOTP secret
  mfaRecoveryCodes String? // JSON array of hashed one-time recovery codes

  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  oauthAccounts      OAuthAccount[]
  verificationTokens VerificationToken[]
  auditLogs          AuditLog[]

  // Community / Discuss
  threads      Thread[]
  comments     Comment[]
  threadVotes  ThreadVote[]
  commentVotes CommentVote[]

  // AI Interview
  interviewSessions InterviewSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserStatus {
  ACTIVE
  LOCKED
  DISABLED
}

// A social login linked to a user (Google, GitHub, ...).
model OAuthAccount {
  id                String @id @default(cuid())
  provider          String // "google" | "github"
  providerAccountId String // the user's id at that provider
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String

  createdAt DateTime @default(now())

  @@unique([provider, providerAccountId])
}

// Short-lived one-time tokens for email verification and password reset.
model VerificationToken {
  id        String                @id @default(cuid())
  type      VerificationTokenType
  tokenHash String                @unique // we store only the hash
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime              @default(now())

  @@index([userId])
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// An immutable trail of security-relevant events.
model AuditLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  event     String
  ip        String?
  userAgent String?
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([event])
}

// ── Community / Discuss ──────────────────────────────────────────────────────

// A discussion thread anyone logged-in can start.
model Thread {
  id        String       @id @default(cuid())
  title     String
  body      String
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  comments  Comment[]
  votes     ThreadVote[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([createdAt])
  @@index([authorId])
}

// A flat comment on a thread.
model Comment {
  id        String        @id @default(cuid())
  body      String
  thread    Thread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  votes     CommentVote[]
  createdAt DateTime      @default(now())

  @@index([threadId])
  @@index([authorId])
}

// One vote per user per thread (value is +1 or -1).
model ThreadVote {
  id       String @id @default(cuid())
  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  value    Int

  @@unique([threadId, userId])
}

// One vote per user per comment (value is +1 or -1).
model CommentVote {
  id        String  @id @default(cuid())
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  value     Int

  @@unique([commentId, userId])
}

// ── AI Interview ─────────────────────────────────────────────────────────────

// A finished mock interview. Live state lives in Redis during the session; only
// the completed run is persisted here for history + the scorecard.
model InterviewSession {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  role       String                 // dsa | system_design | business | hr
  transcript Json                    // full visible turns array
  scorecard  Json                    // { overall, summary, dimensions[], strengths, gaps, perDifficulty }
  durationS  Int
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}
