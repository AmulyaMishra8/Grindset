# ---- Server ----
NODE_ENV=development
PORT=4000

# Where the React app runs (used for CORS + links in emails).
WEB_ORIGIN=http://localhost:5173
# Public URL of THIS api (used inside email links).
APP_URL=http://localhost:4000

# ---- Data stores ----
DATABASE_URL=postgresql://auth:auth@localhost:5432/auth?schema=public
REDIS_URL=redis://localhost:6379

# ---- JWT signing keys (generate with: npm run keys) ----
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=auth-service
JWT_AUDIENCE=auth-clients

# Lifetimes (seconds).
ACCESS_TOKEN_TTL=900          # 15 minutes
REFRESH_TOKEN_TTL=1209600     # 14 days
MFA_TOKEN_TTL=300             # 5 minutes (the between-steps login token)

# ---- Cookies ----
# Set to true in production (HTTPS only).
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ---- MFA ----
MFA_ISSUER=My Auth Service
# Used to encrypt TOTP secrets at rest. Generate a long random value for prod.
ENCRYPTION_KEY=dev-only-insecure-key-change-me

# ---- OAuth social login (optional) ----
# Google:  https://console.cloud.google.com/apis/credentials
#   Authorised redirect URI:  http://localhost:4000/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub:  https://github.com/settings/developers
#   Authorization callback URL:  http://localhost:4000/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Email (SMTP). Leave blank in dev to print emails to the console. ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Auth Service <no-reply@example.com>"

# ---- AI Interview (Groq: LLM interviewer + Whisper STT) ----
# Reuse the same Groq account/keys as judge-service.
FIRST_GROQ_KEY=
SECOND_GROQ_KEY=
THIRD_GROQ_KEY=
# Interviews a user may start per UTC day.
INTERVIEW_DAILY_LIMIT=2
